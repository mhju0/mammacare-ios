# ==========================================================
# MammaCare (personal) — .gitignore
# ==========================================================

# --- 업로드 이미지 (로컬 파일 저장 - 커밋 금지) ---
backend/uploads/

# --- DB 덤프 / 데이터 사본 (PII - 절대 커밋 금지) ---
*.dump

# --- ChromaDB (AI 잔재 - 폴더 없으면 추후 제거 가능) ---
backend/data/chroma_db/

# --- Python (FastAPI) ---
__pycache__/
*.py[cod]
*.pyo
*.pyc
*$py.class
*.egg-info/
dist/
build/
venv/
env/
.env
.env.production
*.db
*.sqlite3
.pytest_cache/
.coverage
htmlcov/
*.pem
*.ppk
*.key
.mypy_cache/
.ruff_cache/
.tox/
junit.xml
test-results/
*.log
logs/
uvicorn*.log

# --- React (Frontend) ---
node_modules/
/build
/dist
coverage/
.node_repl_history
.eslintcache
.stylelintcache
.prettiercache
*.local
.vite/

# --- IDE & OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo

# --- Docker & Secrets ---
.env.local
.env.*.local
docker-compose.override.y.json

# --- Firebase / GCP 서비스 계정 키 (절대 커밋 금지) ---
firebase_credentials*.json
firebase-credentials.json
firebase-adminsdk*.json
*-firebase-adminsdk-*.json
serviceAccountKey.json
serviceAccount*.json
*_serviceAccount.json
service-account*.json
gcp-credentials.json

# --- AI Agents ---
# 주의: START_HERE.md는 AGENTS.md를 repo에 두라고 함(Claude Code가 읽음).
# AGENTS.md를 ignore하면 Claude Code가 못 읽는다. 의도적으로 뺄 때만 주석 해제.
# AGENTS.md
CLAUDE.md
.claude

# ==========================================================
# Android / Capacitor (현재 iOS 시뮬레이터 단독 - Android는 범위 밖)
# ==========================================================
**/#*.jks
**/*.jks
**/*.keystore
**/*.apk
**/*.aar
**/*.ap_
**/*.aab
**/*.dex
**/*.class
**/local.properties

**/.idea/
**/*.iml

**/.gradle/
**/build/
**/bin/
**/gen/
**/out/

frontend/android/app/src/main/assets/public
frontend/android/app/src/main/assets/capacitor.config.json
frontend/anrdova-android-plugins

frontend/android/app/google-services.json

# --- Firebase 설정 (커밋 금지) ---
GoogleService-Info.plist
**/GoogleService-Info.plist

# ── Database ──────────────────────────────
DATABASE_URL=

# ── JWT ───────────────────────────────────
JWT_SECRET_KEY=
JWT_ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=
REFRESH_TOKEN_EXPIRE_DAYS=

# ── App ───────────────────────────────────
# development / production
APP_ENV=
DEBUG=
APP_HOST=
APP_PORT=

# ── Storage (사진 업로드 — 로컬 파일 저장) ──
# 미설정 시 backend/uploads 사용. Docker에서는 /app/uploads (볼륨 마운트).
UPLOAD_DIR=
# 저장 이미지를 서빙하는 보호 엔드포인트 prefix (기본 /api/media)
MEDIA_BASE_URL=

# ── CORS ──────────────────────────────────
ALLOWED_ORIGINS=

#------- OAuth — Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

#------- OAuth — Kakao
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=
KAKAO_MAP_REST_API_KEY=

#------- OAuth — Naver
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=

# ── Firebase Cloud Messaging ───────────────
# docker-compose 사용 시 프로젝트 루트의 firebase_credentials.json을 마운트합니다.
FIREBASE_CREDENTIALS_PATH=/app/firebase_credentials.json
